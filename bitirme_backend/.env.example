# Backend Environment Variables Template
# .env.example dosyasını .env olarak kopyalayıp değerleri doldurun:
# cp .env.example .env

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=3004
HOST=0.0.0.0
NODE_ENV=development
# NODE_ENV=production # Production için açın

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=pill_reminder_db
DB_PORT=3306

# ============================================================
# SECURITY & JWT
# ============================================================
# JWT Secret'ı GÜÇLÜ ve UNIQUE yapın!
# Örnek: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_very_important
JWT_REFRESH_SECRET=your_refresh_token_secret_also_change_this_in_production

# JWT Expiration
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# CORS CONFIGURATION
# ============================================================
# Virgülle ayrılmış liste. Production'da açık bırakmayın!
CORS_ORIGIN=http://localhost:3004,http://localhost:8081,http://localhost:3001,http://127.0.0.1:3000

# ============================================================
# EXTERNAL APIs
# ============================================================
# OpenFDA API
OPENFDA_API_URL=https://api.fda.gov/drug
OPENFDA_TIMEOUT_MS=10000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Apple OAuth (optional)
APPLE_CLIENT_ID=com.example.app

# ============================================================
# RATE LIMITING
# ============================================================
# Login: 5 denemeden sonra 15 dakika block
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000

# Search: 1 dakikada 30 arama
RATE_LIMIT_SEARCH_REQUESTS=30
RATE_LIMIT_SEARCH_WINDOW_MS=60000

# API: 1 saatte 100 istek
RATE_LIMIT_API_REQUESTS=100
RATE_LIMIT_API_WINDOW_MS=3600000

# ============================================================
# CACHING (Optional)
# ============================================================
# Local file-based cache (default)
CACHE_TYPE=file
CACHE_EXPIRY_HOURS=7

# Redis Cache (Production recommended)
# CACHE_TYPE=redis
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
# LOG_LEVEL=debug   # Development
# LOG_LEVEL=warn    # Production

# Log file locations (relative paths)
LOG_ERROR_FILE=logs/error.log
LOG_COMBINED_FILE=logs/combined.log
LOG_REQUESTS_FILE=logs/requests.log

# ============================================================
# EMAIL CONFIGURATION (for notifications - optional)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=noreply@medireminder.com

# ============================================================
# DATABASE BACKUPS
# ============================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * * # Cron format: Her gün saat 2:00 AM
BACKUP_RETENTION_DAYS=30

# ============================================================
# MONITORING & ANALYTICS (Optional)
# ============================================================
# Prometheus metrics
METRICS_ENABLED=false
METRICS_PORT=9090

# Sentry error tracking
# SENTRY_DSN=https://your_sentry_url

# DataDog APM
# DD_SERVICE=medireminder-backend
# DD_ENV=production
# DD_VERSION=1.0.0

# ============================================================
# SECURITY HEADERS
# ============================================================
# Helmet.js CSP
CSP_DIRECTIVES=default-src 'self'; script-src 'self' 'unsafe-inline'

# HSTS (HTTP Strict Transport Security)
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# ============================================================
# GDPR / KVKK COMPLIANCE
# ============================================================
ENABLE_DATA_EXPORT=true
ENABLE_DATA_DELETION=true
DATA_RETENTION_DAYS=365
AUDIT_LOGGING_ENABLED=true

# ============================================================
# PAYMENT PROCESSING (if applicable)
# ============================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# ENVIRONMENT-SPECIFIC OVERRIDES
# ============================================================

# DEVELOPMENT ONLY
if [ "$NODE_ENV" = "development" ]; then
  LOG_LEVEL=debug
  RATE_LIMIT_DISABLED=false  # false = enabled
  CORS_ORIGIN=*
fi

# PRODUCTION ONLY
if [ "$NODE_ENV" = "production" ]; then
  LOG_LEVEL=warn
  RATE_LIMIT_DISABLED=false  # always enabled
  CACHE_TYPE=redis
  AUDIT_LOGGING_ENABLED=true
fi

# ============================================================
# NOTES
# ============================================================
# 
# 1. Bu template'i .env olarak kopyalayın:
#    $ cp .env.example .env
#
# 2. Tüm değerleri gerçek değerlerle doldurun
#
# 3. .env'yi .gitignore'a ekleyin (credentials açık olmasın):
#    echo ".env" >> .gitignore
#
# 4. Production ortamında:
#    - Tüm secrets'ları AWS Secrets Manager, HashiCorp Vault, vb. kullanın
#    - NODE_ENV=production
#    - CORS_ORIGIN'ı whitelist yapın
#    - HTTPS/TLS enforced olsun
#    - Database'i encrypted backup'ını alın
#
# 5. JWT_SECRET oluşturma:
#    $ openssl rand -base64 32
#
# 6. Database password güçlü olmalı:
#    - Minimum 12 karakter
#    - Uppercase, lowercase, number, special char içermeli
#    - Örnek: Tr0picaL!P4ssw0rd123
#
# ============================================================
